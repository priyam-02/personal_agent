# ─── Gmail OAuth2 ───
# Get these from Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=  # Generated by setup_gmail.py

# ─── Nemoclaw Settings ───
# Comma-separated labels to watch (default: INBOX)
GMAIL_LABELS=INBOX
# Max emails to process per poll cycle
MAX_EMAILS_PER_POLL=10
# Categories to skip (comma-separated): promotions, social, updates, forums
SKIP_CATEGORIES=promotions,social,updates,forums
# SQLite database path (inside sandbox)
DB_PATH=/sandbox/nemoclaw.db
